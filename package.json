{
  "name": "musil",
  "version": "1.0.0",
  "scripts": {
    "start": "ng serve --port 4200 --open",
    "build": "ng build",
    "test": "ng test",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "stats": "ng build --prod --stats-json",
    "analyze": "webpack-bundle-analyzer dist/musil/browser/stats.json",
    "build:dev": "ng build && tsc server.ts render.ts --outDir dist/",
    "start:dev": "npm run build && ts-node-dev -O '{\"module\":\"commonjs\"}' --respawn server.ts",
    "build:prod": "ng build --prod && tsc server.ts render.ts --outDir dist/",
    "start:prod": "NODE_ENV=production node server.js",
    "gcloud:show": "gcloud config configurations list",
    "gcloud:deploy": "cp package.json dist/ && cp package-lock.json dist/ && cp app.yaml dist/ && gcloud app deploy dist/app.yaml"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^11.2.12",
    "@angular/cdk": "^11.2.13",
    "@angular/common": "^11.2.12",
    "@angular/compiler": "^11.2.12",
    "@angular/core": "^11.2.12",
    "@angular/fire": "^6.1",
    "@angular/forms": "^11.2.12",
    "@angular/material": "^11.2.13",
    "@angular/platform-browser": "^11.2.12",
    "@angular/platform-browser-dynamic": "^11.2.12",
    "@angular/router": "^11.2.12",
    "@angular/service-worker": "^11.2.12",
    "algoliasearch": "^4.8.3",
    "angular-froala-wysiwyg": "^3.2.7",
    "express": "^4.15.2",
    "firebase": "^8.2.1",
    "firebase-admin": "^9.11.0",
    "froala-editor": "^3.2.7",
    "html-to-text": "^8.0.0",
    "ngx-image-cropper": "^3.3.2",
    "ngx-infinite-scroll": "^10.0.1",
    "rxjs": "~6.5.4",
    "tslib": "^2.0.0",
    "zone.js": "~0.10.2"
  },
  "devDependencies": {
    "@angular-devkit/architect": "~0.1102.11",
    "@angular-devkit/build-angular": "^0.1102.11",
    "@angular-eslint/builder": "4.2.0",
    "@angular-eslint/eslint-plugin": "4.2.0",
    "@angular-eslint/eslint-plugin-template": "4.2.0",
    "@angular-eslint/schematics": "4.2.0",
    "@angular-eslint/template-parser": "4.2.0",
    "@angular/cli": "^11.2.11",
    "@angular/compiler-cli": "^11.2.12",
    "@angular/language-service": "^11.2.12",
    "@types/html-to-text": "^8.0.1",
    "@types/jasmine": "~3.6.0",
    "@types/jasminewd2": "~2.0.3",
    "@types/node": "^12.12.50",
    "@typescript-eslint/eslint-plugin": "4.16.1",
    "@typescript-eslint/parser": "4.16.1",
    "bufferutil": "^4.0.3",
    "eslint": "^7.6.0",
    "firebase-tools": "^9.10.0",
    "fuzzy": "^0.1.3",
    "inquirer": "^6.2.2",
    "inquirer-autocomplete-prompt": "^1.0.1",
    "jasmine-core": "~3.6.0",
    "jasmine-spec-reporter": "~5.0.0",
    "karma": "~6.3.2",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage-istanbul-reporter": "~3.0.2",
    "karma-jasmine": "~4.0.0",
    "karma-jasmine-html-reporter": "^1.5.0",
    "open": "^7.0.3",
    "protractor": "~7.0.0",
    "ts-node": "~8.3.0",
    "ts-node-dev": "^1.1.8",
    "typescript": "~4.0.5",
    "webpack-bundle-analyzer": "^4.4.0"
  }
}
